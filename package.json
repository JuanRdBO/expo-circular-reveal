{
  "name": "expo-circular-reveal-monorepo",
  "private": true,
  "packageManager": "bun@1.3.13",
  "scripts": {
    "start": "bun run --cwd example start",
    "android": "bun run --cwd example build-android-dev",
    "ios": "bun run --cwd example build-ios-dev",
